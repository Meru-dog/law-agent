
  # ========================================
  # Law RAG Application Configuration
  # Copy this file to .env and fill in your values
  # ========================================

  # Application Settings
  LAW_RAG_APP_NAME=law-rag-app
  LAW_RAG_ENVIRONMENT=development
  LAW_RAG_DEBUG=true
  LAW_RAG_LOG_LEVEL=INFO
  LAW_RAG_LOG_FORMAT=console

  # Database Configuration
  LAW_RAG_DATABASE_URL=postgresql://lawrag:lawrag@localhost:5432/lawrag

  # File Storage
  LAW_RAG_STORAGE_PATH=./storage/documents

  # Embeddings
  LAW_RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
  LAW_RAG_EMBEDDING_DIMENSION=384

  # Chunking
  LAW_RAG_CHUNK_SIZE=500
  LAW_RAG_CHUNK_OVERLAP=50

  # LLM Configuration (Gemini API)
  # Get your API key from: https://makersuite.google.com/app/apikey
  LAW_RAG_GEMINI_API_KEY=your-gemini-api-key-here
  LAW_RAG_GEMINI_MODEL=gemini-1.5-pro
  LAW_RAG_MAX_CONTEXT_CHUNKS=10

  # Neo4j Configuration
  LAW_RAG_NEO4J_URI=bolt://localhost:7687
  LAW_RAG_NEO4J_USER=neo4j
  LAW_RAG_NEO4J_PASSWORD=your-neo4j-password-here

  # Authorization (JSON mapping of user_id to list of matter_ids)
  # Example: {"alice":["matter-1","matter-2"],"bob":["matter-2","matter-3"]}
  LAW_RAG_USER_MATTERS={"alice":["matter-1"]}

